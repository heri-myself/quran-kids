FROM python:3.11-slim

RUN apt-get update && apt-get install -y ffmpeg && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY requirements.sidecar.txt /app/requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

COPY tilawah_service.py /app/tilawah_service.py
COPY tajweed_engine.py /app/tajweed_engine.py

EXPOSE 8001

CMD ["python3", "-m", "uvicorn", "tilawah_service:app", "--host", "0.0.0.0", "--port", "8001"]
